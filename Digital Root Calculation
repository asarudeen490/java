import java.util.*;
public class split{
    public static void main(String[] args){
        int n;
        Scanner sc=new Scanner(System.in);
        System.out.print("Enter the value of n:");
        n=sc.nextInt();
        int original_num=n;
        while(n>9){
            int sum=0;
            while(n>0){
                sum+=n%10;
                n=n/10;
            }
            n=sum;
        }
        System.out.println("Digital root:"+n);
    }
}
